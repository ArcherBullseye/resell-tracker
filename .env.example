# eBay Developer App ID (Client ID)
# Get yours free at https://developer.ebay.com/
# Required for eBay sold price lookups
EBAY_APP_ID=

# UPC Item DB API key (optional)
# Free tier (100 lookups/day) works without a key
# Paid tier: https://www.upcitemdb.com/
UPC_API_KEY=

# Port (default: 3000)
PORT=3000
