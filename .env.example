# ── Required for eBay sold price lookups ────────────────────────────────────
# Get a free App ID at https://developer.ebay.com/
EBAY_APP_ID=

# ── Optional: UPC Item DB API key ────────────────────────────────────────────
# Free tier (100 lookups/day) works without a key.
# Paid tier: https://www.upcitemdb.com/
UPC_API_KEY=

# ── Internal settings (do not change unless you know what you're doing) ──────
PORT=3000
DATA_DIR=/app/data
