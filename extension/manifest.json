{
  "manifest_version": 3,
  "name": "Resell Tracker Scanner",
  "version": "1.1.0",
  "description": "Scan retailer clearance pages — buffer across multiple sites, then download one file to upload into Resell Tracker.",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "host_permissions": [
    "https://*.lowes.com/*",
    "https://*.tractorsupply.com/*",
    "https://*.homedepot.com/*",
    "https://*.walmart.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Resell Tracker Scanner"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lowes.com/*",
        "https://*.tractorsupply.com/*",
        "https://*.homedepot.com/*",
        "https://*.walmart.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
